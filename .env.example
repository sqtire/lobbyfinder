# ---- worker service ----
REDIS_URL=            # Railway: reference ${{Redis.REDIS_URL}}
OSU_CLIENT_ID=        # from https://osu.ppy.sh/home/account/edit#oauth
OSU_CLIENT_SECRET=
KEY_PREFIX=mpf        # optional; MUST match between worker and web

# ---- web service ----
# REDIS_URL=          # same Redis reference as the worker
APP_PASSWORD=         # password to unlock editing
SESSION_SECRET=       # random; generate with: openssl rand -hex 32
# KEY_PREFIX=mpf      # must match the worker
